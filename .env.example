WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret
WECHAT_TEMPLATE_ID=your_template_id
# Multiple users format (JSON array or comma-separated):
# JSON array: WECHAT_TO_USER_OPENIDS=["openid1", "openid2", "openid3"]
# Comma-separated: WECHAT_TO_USER_OPENIDS=openid1,openid2,openid3
WECHAT_TO_USER_OPENIDS=["openid1", "openid2"]
# Legacy single user format (still supported):
# WECHAT_TO_USER_OPENID=your_openid

# Timezone for rendering date fields
TZ=Asia/Shanghai

# Toggle weather data (QWeather API)
ENABLE_WEATHER=false
QWEATHER_API_KEY=
WEATHER_LOCATION=Beijing

# Message content
FIXED_TITLE=早安提醒
FIXED_REMARK=祝你今天顺利
ANNIVERSARY_DATE=2024-12-31
ANNIVERSARY_NAME=在一起

# If your template uses different parameter names, change these mappings.
FIELD_FIRST=first
FIELD_DATE=date
FIELD_WEEKDAY=weekday
FIELD_WEATHER=weather
FIELD_ANNIVERSARY=anniversary
FIELD_REMARK=remark

REQUEST_TIMEOUT_SECONDS=10
